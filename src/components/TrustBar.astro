<section class="trust-bar">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="trust-text">
          <strong>30 Tage Probezeit</strong>
          <span>Kostenlos testen, bei Nichtgefallen zurücksenden</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="trust-text">
          <strong>Kostenloser Versand</strong>
          <span>Hin- und Rückversand gratis</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="trust-text">
          <strong>Expertenberatung</strong>
          <span>Professionelle Fernanpassung inklusive</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="trust-text">
          <strong>Bis zu 50% günstiger</strong>
          <span>Faire Preise ohne Zwischenhändler</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .trust-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .trust-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .trust-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .trust-text strong {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .trust-text span {
    font-size: 0.825rem;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .trust-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
