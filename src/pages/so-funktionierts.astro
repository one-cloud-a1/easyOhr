---
import BaseLayout from '../layouts/BaseLayout.astro'
import ProcessSteps from '../components/ProcessSteps.astro'
import { url } from '../lib/links'
---
<BaseLayout title="So funktioniert's" description="In 4 einfachen Schritten zu Ihrem Hörgerät. Online bestellen, 30 Tage testen, erst zahlen wenn Sie zufrieden sind.">
  <section class="page-header">
    <div class="container">
      <h1>So funktioniert easyOhr</h1>
      <p>In 4 einfachen Schritten zu Ihrem perfekten Hörgerät</p>
    </div>
  </section>

  <ProcessSteps />

  <section class="section">
    <div class="container">
      <div class="details-grid">
        <div class="detail-block">
          <div class="detail-number">1</div>
          <h3>Hörgerät auswählen</h3>
          <p>Stöbern Sie durch unsere Auswahl an Premium-Hörgeräten von Phonak, Oticon und Starkey. Nutzen Sie unsere Filter, um das passende Gerät zu finden, oder vergleichen Sie bis zu 3 Modelle direkt miteinander.</p>
          <p>Unsicher? Rufen Sie uns an — wir beraten Sie kostenlos und unabhängig.</p>
        </div>
        <div class="detail-block">
          <div class="detail-number">2</div>
          <h3>Bestellen & zugesendet bekommen</h3>
          <p>Geben Sie im Checkout Ihre Daten und Zahlungsmethode an. <strong>Es wird kein Geld abgebucht</strong> — die Zahlung wird nur für später autorisiert.</p>
          <p>Wir senden Ihnen das Hörgerät kostenlos innerhalb von 3-5 Werktagen zu.</p>
        </div>
        <div class="detail-block">
          <div class="detail-number">3</div>
          <h3>30 Tage testen</h3>
          <p>Testen Sie Ihr neues Hörgerät in Ihrem gewohnten Alltag — zu Hause, bei der Arbeit, im Restaurant. Unser Hörakustiker passt es per Video-Termin optimal an Ihr Hörvermögen an.</p>
          <p>Nachjustierungen sind jederzeit möglich und im Preis inklusive.</p>
        </div>
        <div class="detail-block">
          <div class="detail-number">4</div>
          <h3>Entscheiden</h3>
          <p><strong>Zufrieden?</strong> Dann wird die Zahlung eingezogen. Ihr Hörgerät gehört Ihnen mit voller Herstellergarantie.</p>
          <p><strong>Nicht zufrieden?</strong> Senden Sie das Gerät kostenlos zurück. Es entstehen keine Kosten.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="text-align: center; max-width: 640px;">
      <h2>Noch Fragen?</h2>
      <p style="color: var(--color-text-light); margin: 1rem 0 2rem; font-size: 1.1rem;">Wir beraten Sie gerne persönlich — kostenlos und unverbindlich.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="tel:+4930123456789" class="btn btn-primary btn-lg">030 1234 56789</a>
        <a href={url('/faq/')} class="btn btn-outline btn-lg">Häufige Fragen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: var(--color-secondary);
    padding: 3rem 0;
    text-align: center;
  }

  .page-header p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    margin-top: 0.75rem;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .detail-block {
    padding: 2rem;
    background: white;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    position: relative;
  }

  .detail-number {
    position: absolute;
    top: -12px;
    left: 1.5rem;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    color: white;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail-block h3 {
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  .detail-block p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .detail-block p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .details-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
