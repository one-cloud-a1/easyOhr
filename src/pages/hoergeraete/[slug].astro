---
import BaseLayout from '../../layouts/BaseLayout.astro'
import AddToCart from '../../components/AddToCart.tsx'
import products from '../../data/products.json'
import { url } from '../../lib/links'

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }))
}

const { product } = Astro.props

const related = products
  .filter(p => p.hersteller === product.hersteller && p.slug !== product.slug)
  .slice(0, 3)

const bauform = product.typ === 'CIC' ? 'CIC / Im-Ohr' : 'RIC / Ex-Hörer'
const bauformLang = product.typ === 'CIC'
  ? 'Kompaktes Im-Ohr-Hörgerät — nahezu unsichtbar im Gehörgang'
  : 'Hinter-dem-Ohr mit externem Hörer — diskret und leistungsstark'
---
<BaseLayout title={product.name} description={`${product.name} — ${product.beschreibung.slice(0, 150)}`}>
  <section class="product-detail">
    <div class="container">
      <nav class="breadcrumb">
        <a href={url('/')}>Start</a>
        <span>/</span>
        <a href={url('/hoergeraete/')}>Hörgeräte</a>
        <span>/</span>
        <span>{product.name}</span>
      </nav>

      <div class="detail-grid">
        <div class="detail-image-col">
          <div class="detail-image-main">
            <div class="detail-image-badge-row">
              <span class={`detail-badge ${product.technologie === 'Premium' ? 'badge-premium' : product.technologie === 'Advanced' ? 'badge-advanced' : product.technologie === 'Standard' ? 'badge-standard' : 'badge-basis'}`}>
                {product.technologie}
              </span>
              <span class="detail-badge-type">{bauform}</span>
            </div>
            <img
              src={url(product.bild)}
              alt={product.name}
              class="detail-product-img"
              loading="eager"
            />
          </div>
          <div class="detail-image-info">
            <div class="detail-image-info-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>{product.schutzklasse} — wasser- und staubgeschützt</span>
            </div>
            <div class="detail-image-info-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
              <span>{product.akkuLaufzeit} Akkulaufzeit</span>
            </div>
            <div class="detail-image-info-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>
              <span>{bauformLang}</span>
            </div>
          </div>
        </div>

        <div class="detail-info">
          <span class="detail-brand">{product.hersteller}</span>
          <h1>{product.name}</h1>

          <p class="detail-desc">{product.beschreibung}</p>

          <div class="detail-quick-specs">
            <div class="quick-spec">
              <span class="quick-spec-val">{product.akkuLaufzeit}</span>
              <span class="quick-spec-label">Akku</span>
            </div>
            <div class="quick-spec">
              <span class="quick-spec-val">{product.schutzklasse}</span>
              <span class="quick-spec-label">Schutz</span>
            </div>
            <div class="quick-spec">
              <span class="quick-spec-val">{product.gewicht}</span>
              <span class="quick-spec-label">Gewicht</span>
            </div>
            <div class="quick-spec">
              <span class="quick-spec-val">{product.farben.length}</span>
              <span class="quick-spec-label">Farben</span>
            </div>
          </div>

          <div class="detail-actions">
            <AddToCart
              client:load
              slug={product.slug}
              name={product.name}
              hersteller={product.hersteller}
              privatpreis={product.privatpreis}
              kassenpreis={product.kassenpreis}
              farben={product.farben}
            />
          </div>
        </div>
      </div>

      <div class="detail-features-section">
        <h2>Features & Technologie</h2>
        <div class="features-grid">
          {product.features.map((f: string) => (
            <div class="feature-card">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{f}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="detail-specs">
        <h2>Technische Details</h2>
        <div class="specs-table">
          <div class="spec-row">
            <span class="spec-label">Hersteller</span>
            <span class="spec-value">{product.hersteller}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Familie</span>
            <span class="spec-value">{product.familie}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Bauform</span>
            <span class="spec-value">{bauform}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Technologie-Level</span>
            <span class="spec-value">{product.technologie}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Akkulaufzeit</span>
            <span class="spec-value">{product.akkuLaufzeit}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Schutzklasse</span>
            <span class="spec-value">{product.schutzklasse}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Gewicht</span>
            <span class="spec-value">{product.gewicht}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Verfügbare Farben</span>
            <span class="spec-value">{product.farben.join(', ')}</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Privatpreis pro Ohr</span>
            <span class="spec-value">{product.privatpreis.toLocaleString('de-DE')} €</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Mit Krankenkasse ab</span>
            <span class="spec-value spec-value-highlight">{product.kassenpreis.toLocaleString('de-DE')} €</span>
          </div>
        </div>
      </div>

      <div class="detail-trust">
        <div class="trust-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div>
            <strong>30 Tage testen</strong>
            <span>Kostenlos testen, bei Nichtgefallen zurücksenden</span>
          </div>
        </div>
        <div class="trust-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <div>
            <strong>Erst zahlen bei Gefallen</strong>
            <span>Kein Geld wird bei der Bestellung abgebucht</span>
          </div>
        </div>
        <div class="trust-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <div>
            <strong>Kostenloser Versand</strong>
            <span>Hin- und Rückversand gratis</span>
          </div>
        </div>
      </div>

      {related.length > 0 && (
        <div class="related-section">
          <h2>Weitere {product.hersteller} Hörgeräte</h2>
          <div class="related-grid">
            {related.map(r => (
              <a href={url(`/hoergeraete/${r.slug}/`)} class="related-card">
                <div class="related-image">
                  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.25">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                  </svg>
                </div>
                <div>
                  <h4>{r.name}</h4>
                  <span class="related-price">ab {r.kassenpreis.toLocaleString('de-DE')} € mit Kasse</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 1.5rem 0;
  }

  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-primary); }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .detail-image-col {
    position: sticky;
    top: calc(var(--header-height) + 1.5rem);
    align-self: start;
  }

  .detail-image-main {
    background: var(--color-secondary);
    border-radius: var(--radius-xl);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 380px;
  }

  .detail-image-badge-row {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    right: 1.25rem;
    display: flex;
    justify-content: space-between;
  }

  .detail-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
  }

  .detail-badge-type {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: white;
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
  }

  .badge-premium { background: var(--color-accent-light); color: var(--color-accent); }
  .badge-advanced { background: var(--color-primary-light); color: var(--color-primary); }
  .badge-standard { background: #F1EFE8; color: var(--color-text-light); }
  .badge-basis { background: #E8E6E0; color: var(--color-text-muted); }

  .detail-product-img {
    max-width: 85%;
    max-height: 300px;
    object-fit: contain;
  }

  .detail-image-info {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 1.25rem;
  }

  .detail-image-info-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .detail-brand {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
  }

  .detail-info h1 {
    font-size: 2rem;
    margin: 0.5rem 0 1rem;
  }

  .detail-desc {
    font-size: 1.05rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .detail-quick-specs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .quick-spec {
    text-align: center;
    padding: 0.75rem 0.5rem;
    background: var(--color-secondary);
    border-radius: var(--radius-md);
  }

  .quick-spec-val {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.125rem;
  }

  .quick-spec-label {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .detail-features-section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border-light);
  }

  .detail-features-section h2 {
    margin-bottom: 1.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .feature-card {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9rem;
    padding: 0.875rem 1rem;
    background: var(--color-primary-light);
    border-radius: var(--radius-md);
    color: var(--color-primary-dark);
  }

  .detail-specs {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border-light);
  }

  .detail-specs h2 {
    margin-bottom: 1.5rem;
  }

  .specs-table {
    max-width: 640px;
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .spec-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .spec-value {
    font-size: 0.9rem;
    font-weight: 600;
    text-align: right;
    max-width: 60%;
  }

  .spec-value-highlight {
    color: var(--color-primary);
  }

  .detail-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 3rem 0;
    border-top: 1px solid var(--color-border-light);
  }

  .trust-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-secondary);
    border-radius: var(--radius-lg);
  }

  .trust-card svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .trust-card strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .trust-card span {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .related-section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border-light);
  }

  .related-section h2 { margin-bottom: 1.5rem; }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .related-card:hover { border-color: var(--color-primary); }

  .related-image {
    width: 60px;
    height: 60px;
    background: var(--color-secondary);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .related-card h4 { font-size: 0.95rem; margin-bottom: 0.25rem; }
  .related-price { font-size: 0.85rem; color: var(--color-primary); font-weight: 600; }

  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .detail-image-col {
      position: static;
    }

    .detail-quick-specs {
      grid-template-columns: repeat(2, 1fr);
    }

    .features-grid {
      grid-template-columns: 1fr 1fr;
    }

    .detail-trust {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .detail-image-main {
      min-height: 280px;
    }
  }

  @media (max-width: 480px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
