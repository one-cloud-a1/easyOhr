---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProductFilter from '../../components/ProductFilter.tsx'
import products from '../../data/products.json'
import '../../styles/product-filter.css'
---
<BaseLayout title="Hörgeräte" description="Alle Hörgeräte von Phonak, Oticon und Starkey. RIC und Ex-Hörer Modelle — bis zu 50% günstiger. 30 Tage kostenlos testen.">
  <section class="page-header">
    <div class="container">
      <h1>Unsere Hörgeräte</h1>
      <p>Finden Sie das perfekte Hörgerät — alle Modelle mit 30 Tagen Probezeit</p>
    </div>
  </section>

  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <ProductFilter client:load products={products} />
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: var(--color-secondary);
    padding: 3rem 0;
    text-align: center;
  }

  .page-header p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    margin-top: 0.75rem;
  }
</style>
